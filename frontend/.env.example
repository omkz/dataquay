# FastAPI backend used by the server-rendered dataset overview.
DATAQUAY_BACKEND_URL=http://localhost:8000

# Auth.js application secret. Generate a separate random value for each environment.
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Auth.js uses the same PostgreSQL database as FastAPI. Alembic owns its schema.
AUTH_DATABASE_URL=postgresql://dataquay:change-me@localhost:5432/dataquay

# Local magic-link delivery through Mailpit (SMTP 1025, web inbox 8025).
EMAIL_SERVER=smtp://localhost:1025
EMAIL_FROM=DataQuay <no-reply@dataquay.local>

# Must exactly match backend DATAQUAY_INTERNAL_AUTH_SECRET. Server-only.
DATAQUAY_INTERNAL_AUTH_SECRET=
