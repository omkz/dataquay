# PydanticAI provider-qualified model used by the Data Steward Agent.
DATAQUAY_AI_MODEL=openai:gpt-5.6

# Required when using the OpenAI provider. Leave empty in committed templates.
# For another provider, set that provider's credential in backend/.env.local.
OPENAI_API_KEY=

# Optional local root for uploaded dataset workspaces.
DATAQUAY_DATA_ROOT=.dataquay/datasets

# PostgreSQL stores workflow metadata only; dataset file contents remain local.
# Replace the password in backend/.env.local. Do not commit real credentials.
DATAQUAY_DATABASE_URL=postgresql+psycopg://dataquay:change-me@localhost:5432/dataquay

# Shared only with the Next.js server. Use a separate random value of at least
# 32 bytes; never expose it through a NEXT_PUBLIC_ variable.
DATAQUAY_INTERNAL_AUTH_SECRET=
