# Used by the Next.js server to fetch the FastAPI inspection endpoint.
DATAQUAY_BACKEND_URL=http://localhost:8000

# Required by the Data Steward Agent. Use a PydanticAI provider-qualified model.
DATAQUAY_AI_MODEL=openai:gpt-5.6

# Required when DATAQUAY_AI_MODEL uses the OpenAI provider.
# For another provider, set that provider's credential environment variable instead.
OPENAI_API_KEY=
